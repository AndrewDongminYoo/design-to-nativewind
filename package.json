{
  "name": "figma-to-nativewind",
  "version": "0.1.0",
  "private": true,
  "description": "Figma plugin that converts a selected design subtree into React Native + NativeWind code.",
  "license": "MIT",
  "author": "Andrew Dongmin Yoo",
  "scripts": {
    "build": "build-figma-plugin --typecheck --minify",
    "watch": "build-figma-plugin --typecheck --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@create-figma-plugin/ui": "^4.0.1",
    "@create-figma-plugin/utilities": "^4.0.1",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^4.0.1",
    "@create-figma-plugin/tsconfig": "^4.0.1",
    "@figma/plugin-typings": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^8.57.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "figma-plugin": {
    "editorType": ["figma", "dev"],
    "id": "figma-to-nativewind",
    "name": "Figma to NativeWind",
    "main": "src/main.ts",
    "ui": "src/ui.tsx",
    "networkAccess": {
      "allowedDomains": ["https://api.anthropic.com"],
      "reasoning": "Optional LLM-assisted cleanup pass via the Claude API."
    }
  }
}
