{
  "name": "design-to-nativewind",
  "version": "0.1.0",
  "private": true,
  "description": "Figma plugin that converts a selected design subtree into React Native + NativeWind code.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewDongminYoo/design-to-nativewind.git"
  },
  "author": "Dongmin, Yu <ydm2790@gmail.com> (https://github.com/AndrewDongminYoo)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AndrewDongminYoo/design-to-nativewind/issues"
  },
  "homepage": "https://github.com/AndrewDongminYoo/design-to-nativewind#readme",
  "scripts": {
    "build": "build-figma-plugin --typecheck --minify",
    "watch": "build-figma-plugin --typecheck --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@create-figma-plugin/ui": "^4.0.3",
    "@create-figma-plugin/utilities": "^4.0.3",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "4.0.3",
    "@create-figma-plugin/tsconfig": "^4.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.128.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "figma-plugin": {
    "editorType": [
      "figma",
      "dev"
    ],
    "id": "1653684573206075427",
    "name": "Design to NativeWind",
    "main": "src/main.ts",
    "ui": "src/ui.tsx",
    "capabilities": [
      "codegen"
    ],
    "codegenLanguages": [
      {
        "label": "React Native + NativeWind",
        "value": "rn-nativewind"
      }
    ],
    "codegenPreferences": [
      {
        "itemType": "select",
        "propertyName": "snap",
        "label": "Spacing snap",
        "options": [
          {
            "label": "Strict (exact px)",
            "value": "strict"
          },
          {
            "label": "Default (±1px)",
            "value": "default",
            "isDefault": true
          },
          {
            "label": "Loose (±2px)",
            "value": "loose"
          }
        ]
      },
      {
        "itemType": "select",
        "propertyName": "reuse",
        "label": "Reuse repeated components",
        "options": [
          {
            "label": "On",
            "value": "on",
            "isDefault": true
          },
          {
            "label": "Off",
            "value": "off"
          }
        ]
      },
      {
        "itemType": "action",
        "propertyName": "import",
        "label": "Import theme (tailwind.config / global.css)…"
      }
    ],
    "documentAccess": "dynamic-page",
    "networkAccess": {
      "allowedDomains": [
        "https://api.anthropic.com"
      ],
      "reasoning": "Optional LLM-assisted cleanup pass via the Claude API."
    }
  }
}
