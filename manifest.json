{
  "api": "1.0.0",
  "editorType": ["figma", "dev"],
  "id": "figma-to-nativewind",
  "name": "Figma to NativeWind",
  "main": "build/main.js",
  "ui": "build/ui.js",
  "capabilities": ["codegen"],
  "codegenLanguages": [
    {
      "label": "React Native + NativeWind",
      "value": "rn-nativewind"
    }
  ],
  "codegenPreferences": [
    {
      "itemType": "select",
      "propertyName": "snap",
      "label": "Spacing snap",
      "options": [
        {
          "label": "Strict (exact px)",
          "value": "strict"
        },
        {
          "label": "Default (±1px)",
          "value": "default",
          "isDefault": true
        },
        {
          "label": "Loose (±2px)",
          "value": "loose"
        }
      ]
    },
    {
      "itemType": "select",
      "propertyName": "reuse",
      "label": "Reuse repeated components",
      "options": [
        {
          "label": "On",
          "value": "on",
          "isDefault": true
        },
        {
          "label": "Off",
          "value": "off"
        }
      ]
    },
    {
      "itemType": "action",
      "propertyName": "import",
      "label": "Import theme (tailwind.config / global.css)…"
    }
  ],
  "networkAccess": {
    "allowedDomains": ["https://api.anthropic.com"],
    "reasoning": "Optional LLM-assisted cleanup pass via the Claude API."
  }
}
